# Copy this file to .env.local and fill in the values.

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# All three values live in the Supabase dashboard:
#   Project URL       → Settings → General
#   Publishable key   → Settings → API Keys   (new name for the anon/public key)
#   Secret key        → Settings → API Keys   (new name for the service_role key)
#
# Supabase recently renamed these:
#   - "publishable key" replaces "anon key"     → use NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - "secret key"      replaces "service_role" → use SUPABASE_SERVICE_ROLE_KEY
#
# NEXT_PUBLIC_* vars are bundled into client code — the publishable key is
# safe to expose. The secret key is server-only and must never ship to the
# browser; never prefix it with NEXT_PUBLIC_.

NEXT_PUBLIC_SUPABASE_URL=your_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here
